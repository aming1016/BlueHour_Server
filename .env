# 腾讯云直播配置
# 注意：此文件包含敏感信息，不要提交到GitHub
# 请复制此文件为 .env.local 并填入你的真实配置

# Tencent Cloud Secret（从腾讯云控制台获取）
TENCENT_SECRET_ID=your-secret-id
TENCENT_SECRET_KEY=your-secret-key

# 直播域名配置（从腾讯云控制台获取）
PUSH_DOMAIN=your-push-domain
PLAY_DOMAIN=your-play-domain
PUSH_KEY=your-push-key
PLAY_KEY=your-play-key

# AppName（应用名称）
APP_NAME=BlueHour
